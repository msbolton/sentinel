# SENTINEL Environment Configuration
# Copy to .env and adjust values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=sentinel
DB_USERNAME=sentinel
DB_PASSWORD=sentinel_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=localhost:9092

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=sentinel
KEYCLOAK_CLIENT_ID=sentinel-web
KEYCLOAK_API_CLIENT_ID=sentinel-api

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123

# GeoServer
GEOSERVER_URL=http://localhost:8600/geoserver

# CesiumJS
CESIUM_ION_ACCESS_TOKEN=

# OpenSky
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Service Ports
API_GATEWAY_PORT=3000
ENTITY_SERVICE_PORT=3001
TRACK_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3003
LINK_ANALYSIS_SERVICE_PORT=3004
ALERT_SERVICE_PORT=3005
INGEST_SERVICE_PORT=4000
ANALYTICS_SERVICE_PORT=5000
WEB_PORT=4200
