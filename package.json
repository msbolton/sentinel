{
  "name": "@sentinel/source",
  "version": "0.0.1",
  "private": true,
  "description": "SENTINEL - Geospatial Intelligence Platform",
  "scripts": {
    "start": "nx run-many --target=serve --projects=web,api-gateway",
    "start:web": "nx serve web",
    "start:api": "nx serve api-gateway",
    "build": "nx run-many --target=build --all",
    "build:web": "nx build web",
    "build:api": "nx build api-gateway",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "proto:generate": "make proto",
    "docker:infra": "docker-compose -f docker-compose.infra.yml up -d",
    "docker:all": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
