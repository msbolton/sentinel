{
  "name": "track-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/track-service",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/track-service"],
      "options": {
        "commands": ["cd apps/track-service && CGO_ENABLED=1 go build -o ../../dist/apps/track-service/server ./cmd/server"],
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd apps/track-service && go run ./cmd/server"],
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd apps/track-service && go test -v -race ./..."],
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["scope:track-service", "type:microservice"]
}
