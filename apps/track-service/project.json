{
  "name": "track-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/track-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/track-service",
        "main": "apps/track-service/src/main.ts",
        "tsConfig": "apps/track-service/tsconfig.app.json",
        "assets": []
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "track-service:build",
        "port": 3002
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/track-service/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/track-service"],
      "options": {
        "jestConfig": "apps/track-service/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:track-service", "type:microservice"]
}
